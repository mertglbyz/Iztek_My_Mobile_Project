{
  "expo": {
    "name": "Durak Yakınımda",
    "slug": "durak-yakinimda",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "durakyakinimda",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1565C0"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1565C0"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}